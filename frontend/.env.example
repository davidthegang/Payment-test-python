# Backend API URL
# For local: leave empty (uses Vite proxy to localhost:5000)
# For production (Vercel etc.): set to your backend URL (no trailing slash) e.g. https://your-backend.onrender.com
# IMPORTANT for auto-checking: this makes the MD5 polling in KHQRDisplay reach the real backend
# (the poll calls /api/check-payment using this base; without it auto status checks won't work in prod).
VITE_API_URL=

# Note: Do not put secret tokens here. The Bakong token is stored securely in the backend .env only.
