# Bakong API Token from @KHQRNotificationBot or your Bakong developer account
# Get it from the official Bakong portal or notification bot.
# This enables automatic payment status checks by MD5 in /api/check-payment/<md5>
# (used by the frontend polling — keep secret, never send to client).
BAKONG_TOKEN=your_long_bakong_token_here

# Optional: Flask settings
# PORT=5000
